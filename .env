# Necessary variables
# Everything is stored there.
MASTER_FOLDER=/E
# Hostname for Homepage.
HOSTNAME=localhost,master.local,master.lan,master.home

DATA_FOLDER=${MASTER_FOLDER}/data # Folder for the media data (downloads AND library)
CONFIGS_FOLDER=${MASTER_FOLDER}/configs
ADGUARD_CONFIG=${CONFIGS_FOLDER}/adguard

# PIA VPN WireGuard file.
VPN_WG_CONFIG=${CONFIGS_FOLDER}/wg0.conf

# Optional variables
USER_ID=1000
GROUP_ID=${USER_ID}
TIMEZONE=Etc/UTC
HTTP_PROXY_PORT=8888

GLUETUN_FOLDER=${CONFIGS_FOLDER}/gluetun
HOMEPAGE_FOLDER=${CONFIGS_FOLDER}/homepage

SONARR_PORT=8989
SONARR_FOLDER=${CONFIGS_FOLDER}/sonarr

RADARR_PORT=7878
RADARR_FOLDER=${CONFIGS_FOLDER}/radarr

BAZARR_PORT=6767
BAZARR_FOLDER=${CONFIGS_FOLDER}/bazarr

PROWLARR_PORT=9696
PROWLARR_FOLDER=${CONFIGS_FOLDER}/prowlarr

QBITTORRENT_WEBUI_PORT=8080
QBITTORRENT_FOLDER=${CONFIGS_FOLDER}/qbittorrent

SEERR_PORT=5055
SEERR_FOLDER=${CONFIGS_FOLDER}/seerr

JELLYSTAT_PORT=3000
JELLYSTAT_FOLDER=${CONFIGS_FOLDER}/jellystat

# Note that jellyfin also opens: 8920, 7359, 1900 (needed for discovery by apps)
JELLYFIN_PORT=8096
JELLYFIN_FOLDER=${CONFIGS_FOLDER}/jellyfin

GLANCES_PORT=61208

# Homepage API keys for service widgets (fill these in after setup).
# Find API keys in each service's Settings > General > API Key section.
JELLYFIN_API_KEY=
SONARR_API_KEY=
RADARR_API_KEY=
BAZARR_API_KEY=
PROWLARR_API_KEY=
SEERR_API_KEY=
JELLYSTAT_API_KEY=
QBITTORRENT_PASSWORD=adminadmin

